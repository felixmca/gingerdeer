# ── Supabase ─────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# "anon" / "public" key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# If your dashboard shows "publishable" key instead:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key — NEVER expose this to the browser.
# Used server-side only for admin writes and lead linking.
# Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (email) ────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=

# From address for transactional emails.
# Use "onboarding@resend.dev" for testing (Resend sandbox).
# Replace with your own verified domain address for production.
RESEND_FROM_EMAIL=Juice for Teams <onboarding@resend.dev>

# ── App ───────────────────────────────────────────────────
# Public URL used in email CTAs and OAuth redirects.
# No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────
# Comma-separated list of email addresses that can access /admin.
# Server-side only — never prefix with NEXT_PUBLIC_.
ADMIN_EMAILS=you@yourcompany.com,colleague@yourcompany.com
